# Server
PORT=8080

# Database
MONGODB_URI=mongodb://localhost:27017/AICodeEditorDB

# Auth
JWT_SECRET=replace_with_strong_jwt_secret

# Redis
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# AI provider fallback order (left to right)
# Supported values: openrouter,openai,anthropic,xai,gemini
AI_FALLBACK_ORDER=openrouter,openai,anthropic,xai,gemini

# Gemini
GOOGLE_AI_KEY=your_google_ai_key
# Optional: override model in code if you add support
# GEMINI_MODEL=gemini-2.0-flash

# OpenRouter (recommended primary fallback)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# xAI (Grok)
XAI_API_KEY=your_xai_api_key
XAI_MODEL=grok-2-latest
XAI_BASE_URL=https://api.x.ai/v1
